DATABASE_URL=postgresql://nrdpp:nrdpp_secret@localhost:5432/nrdpp_db
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars
PORT=5000
WEB_URL=http://localhost:3000
NODE_ENV=development

# Optional: Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@nrdpp.gov.gh

# Optional: SMS (Africa's Talking)
AT_API_KEY=your_api_key
AT_USERNAME=sandbox
